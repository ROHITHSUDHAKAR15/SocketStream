# Copy to .env and adjust. The server reads these from the environment.

# Network
SS_HOST=127.0.0.1          # use 0.0.0.0 in containers
SS_PORT=5000

# Security
SS_DEBUG=0                 # NEVER set to 1 in production (exposes the debugger)
SS_COOKIE_SECURE=1         # set 0 only when serving plain http locally
# SS_SECRET_KEY=           # if unset, a persistent key is generated in .flask_secret

# Storage
SS_DB=secure_messaging.db
